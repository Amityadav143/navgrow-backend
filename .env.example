# ── Database ──────────────────────────────────────────────────────────────────
DB_URL=jdbc:postgresql://localhost:5432/navgrow_db
DB_USER=navgrow
DB_PASSWORD=your_strong_password

# ── JWT ────────────────────────────────────────────────────────────────────────
JWT_SECRET=your-256-bit-secret-key-minimum-32-characters-long
JWT_EXPIRATION=86400000
JWT_REFRESH=604800000

# ── Email / SMTP ───────────────────────────────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=info@navgrow.org
MAIL_PASSWORD=your_gmail_app_password

# ── Razorpay ───────────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# ── App ────────────────────────────────────────────────────────────────────────
BASE_URL=https://api.navgrow.org
FRONTEND_URL=https://navgrow.org
UPLOAD_DIR=/var/navgrow/uploads
PORT=8080

# ── Anthropic API (Chatbot) ───────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here
