# ═══════════════════════════════════════════════════════════════════════════════
# Navgrow Engineering — LOCAL DEVELOPMENT ENVIRONMENT
# Usage: source .env.local && mvn spring-boot:run -Dspring.profiles.active=dev
#
# ⚠ NEVER commit this file to git — it's in .gitignore
# ⚠ This file has test/dummy credentials only — safe for local dev
# ═══════════════════════════════════════════════════════════════════════════════

# ── Database (local PostgreSQL) ────────────────────────────────────────────────
export DB_URL=jdbc:postgresql://localhost:5432/navgrow_db
export DB_USER=navgrow
export DB_PASSWORD=devpassword123

# ── JWT (dummy secret — DO NOT use in production) ─────────────────────────────
export JWT_SECRET=navgrow-local-dev-secret-key-minimum-32-chars-long-xxxx
export JWT_EXPIRATION=86400000
export JWT_REFRESH=604800000

# ── Email (disabled in dev — emails are logged to console instead) ────────────
export MAIL_HOST=smtp.gmail.com
export MAIL_PORT=587
export MAIL_USERNAME=test@example.com
export MAIL_PASSWORD=test_password_not_used_in_dev

# ── Razorpay TEST Keys ─────────────────────────────────────────────────────────
# These are Razorpay's official TEST mode keys (safe to use, no real money)
export RAZORPAY_KEY_ID=rzp_test_1DP5mmOlF5G5ag
export RAZORPAY_KEY_SECRET=thisShouldBeYourSecret
export RAZORPAY_WEBHOOK_SECRET=test_webhook_secret_navgrow

# ── Anthropic NavBot ───────────────────────────────────────────────────────────
# Option A: Set to TEST to use smart canned responses (no API call, no cost)
export ANTHROPIC_API_KEY=TEST
#
# Option B: Paste your real key from console.anthropic.com
# export ANTHROPIC_API_KEY=sk-ant-api03-your-real-key-here

# ── App URLs ───────────────────────────────────────────────────────────────────
export BASE_URL=http://localhost:8080
export FRONTEND_URL=http://localhost:5173

# ── Spring profile ─────────────────────────────────────────────────────────────
export SPRING_PROFILES_ACTIVE=dev
